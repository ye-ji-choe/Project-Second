--- !u!114 &1197595237
MonoBehaviour:
  m_ObjectHideFlags: 0
  m_CorrespondingSourceObject: {fileID: 0}
  m_PrefabInstance: {fileID: 0}
  m_PrefabAsset: {fileID: 0}
  m_GameObject: {fileID: 1197595235}
  m_Enabled: 1
  m_EditorHideFlags: 0
  m_Script: {fileID: 11500000, guid: e3281dafbd5cb2649a3c26c3cdc46049, type: 3}
  m_Name: 
  m_EditorClassIdentifier: 
  _stepName: 
  _infoMessage: 'Assembly steps:



    1) Attach the front bumper to the main frame

    2)
    Plug the cables to the back of the main frame

    3) Place the frame cover on
    top of the main frame

    4) Place the bridge mount on top of the frame, at
    the end of the main body

    5) Put the cable housing at the base of the bridge
    mount, at the upper side where cables are linked

    6) Take the robot arm chassis,
    slide it into the cutout of the bridge mount

    7) Find the chassis support,
    a rectangular frame with four rod, attach it to the front opening of the arm
    chassis

    8) Take the motor battery, attach it at the rear side of the arm
    chassis by the side

    9) Take the outer arm tube and put it inside the chassis
    support

    10) Take the inner arm tube, attach it inside the outer arm tube

    11)
    Take the claw and attach it to the front of the arm chassis

    12) Take two
    of the gliders and place them on top of the main body

    13) Take the two glider
    wheels and attach them to the front side of the gliders vertically

'
  _objectsToActivate:
  - {fileID: 1291282620}
  - {fileID: 1645109579}
  - {fileID: 532921887}
  - {fileID: 2077175887}
